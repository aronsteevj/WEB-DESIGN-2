<!DOCTYPE html>
<html>
<head>
    <title>4 Section Layout</title>
    <style>
        body {
            margin: 0;
        }

        .container {
            display: grid;
            grid-template-columns: 50% 50%;
            grid-template-rows: 50vh 50vh;
        }

        .box {
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 24px;
            font-weight: bold;
            color: white;
        }

        .box1 {
            background-color: #ff5733;
        }

        .box2 {
            background-color: #33c1ff;
        }

        .box3 {
            background-color: #28a745;
        }

        .box4 {
            background-color: #6f42c1;
        }
    </style>
</head>

<body>

<div class="container">
    <div class="box box1">Section 1</div>
    <div class="box box2">Section 2</div>
    <div class="box box3">Section 3</div>
    <div class="box box4">Section 4</div>
</div>

</body>
</html>
